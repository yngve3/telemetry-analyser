{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telemetry-analyser.local/schemas/anomaly-result.schema.json",
  "title": "AnomalyResult",
  "description": "Pipeline result produced by the analysis module for a telemetry sample.",
  "type": "object",
  "required": [
    "drone_id",
    "telemetry_timestamp",
    "has_anomalies",
    "anomalies",
    "detector_outputs"
  ],
  "properties": {
    "drone_id": {
      "type": "string",
      "minLength": 1
    },
    "telemetry_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "has_anomalies": {
      "type": "boolean"
    },
    "anomalies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/aggregated_anomaly"
      }
    },
    "detector_outputs": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/detector_output"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "anomaly_type": {
      "type": "string",
      "enum": [
        "GPS_SIGNAL_LOSS",
        "GPS_SPOOFING",
        "IMU_SPIKE",
        "BATTERY_DROP",
        "LOW_BATTERY",
        "IMPOSSIBLE_ALTITUDE",
        "TELEMETRY_FREEZE",
        "TELEMETRY_GAP",
        "MOTION_INCONSISTENCY",
        "ANOMALOUS_BEHAVIOR"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "INFO",
        "WARNING",
        "CRITICAL"
      ]
    },
    "detector_kind": {
      "type": "string",
      "enum": [
        "rule_based",
        "model_based"
      ]
    },
    "evidence_value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_value"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/evidence_value"
          }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/evidence_value"
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "anomaly_source": {
      "type": "object",
      "required": [
        "detector",
        "confidence",
        "evidence"
      ],
      "properties": {
        "detector": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "aggregated_anomaly": {
      "allOf": [
        {
          "$ref": "#/$defs/detected_anomaly"
        },
        {
          "type": "object",
          "required": [
            "sources"
          ],
          "properties": {
            "sources": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/anomaly_source"
              }
            }
          }
        }
      ]
    },
    "detected_anomaly": {
      "type": "object",
      "required": [
        "type",
        "severity",
        "message",
        "confidence",
        "source",
        "detector_kind",
        "detector_name",
        "affected_fields",
        "affected_parameters",
        "evidence",
        "diagnostic_evidence"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/anomaly_type"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "detector_kind": {
          "$ref": "#/$defs/detector_kind"
        },
        "detector_name": {
          "type": "string",
          "minLength": 1
        },
        "model_name": {
          "type": "string",
          "minLength": 1
        },
        "score": {
          "type": "number"
        },
        "affected_fields": {
          "$ref": "#/$defs/string_list"
        },
        "affected_parameters": {
          "$ref": "#/$defs/string_list"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "window_start": {
          "type": "string",
          "format": "date-time"
        },
        "window_end": {
          "type": "string",
          "format": "date-time"
        },
        "probable_cause": {
          "type": "string",
          "minLength": 1
        },
        "cause_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "diagnostic_evidence": {
          "$ref": "#/$defs/evidence"
        },
        "recommended_action": {
          "type": "string",
          "minLength": 1
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/anomaly_source"
          }
        }
      },
      "additionalProperties": false
    },
    "detector_output": {
      "type": "object",
      "required": [
        "detector_name",
        "detector_kind",
        "status",
        "anomalies"
      ],
      "properties": {
        "detector_name": {
          "type": "string",
          "minLength": 1
        },
        "detector_kind": {
          "$ref": "#/$defs/detector_kind"
        },
        "status": {
          "type": "string",
          "enum": [
            "ready",
            "not_ready"
          ]
        },
        "message": {
          "type": [
            "string",
            "null"
          ]
        },
        "anomalies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detected_anomaly"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
