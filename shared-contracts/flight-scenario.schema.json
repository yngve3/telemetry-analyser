{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telemetry-analyser.local/schemas/flight-scenario.schema.json",
  "title": "FlightScenario",
  "description": "Portable flight scenario contract for telemetry source configuration.",
  "type": "object",
  "required": [
    "name",
    "frequency_hz",
    "home",
    "steps"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "drone_id": {
      "type": "string",
      "minLength": 1
    },
    "frequency_hz": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "home": {
      "$ref": "#/$defs/home"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "anomalies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/anomaly"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "home": {
      "type": "object",
      "required": [
        "latitude",
        "longitude",
        "altitude",
        "battery"
      ],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "altitude": {
          "type": "number"
        },
        "heading_deg": {
          "type": "number",
          "minimum": 0,
          "maximum": 360
        },
        "battery": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "takeoff",
            "forward",
            "turn",
            "hover",
            "return_home",
            "landing",
            "waypoint"
          ]
        },
        "target_altitude": {
          "type": "number"
        },
        "target_latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "target_longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "distance_m": {
          "type": "number",
          "minimum": 0
        },
        "speed_m_s": {
          "type": "number",
          "minimum": 0
        },
        "direction": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ]
        },
        "angle_deg": {
          "type": "number"
        },
        "duration_sec": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "anomaly": {
      "type": "object",
      "required": [
        "type",
        "start_after_sec",
        "duration_sec",
        "intensity"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "gps_signal_loss",
            "gps_spoofing",
            "imu_spike",
            "battery_drop",
            "low_battery",
            "telemetry_freeze",
            "telemetry_gap",
            "motion_inconsistency",
            "impossible_altitude",
            "anomalous_behavior"
          ]
        },
        "start_after_sec": {
          "type": "number",
          "minimum": 0
        },
        "duration_sec": {
          "type": "number",
          "minimum": 0
        },
        "intensity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    }
  }
}
